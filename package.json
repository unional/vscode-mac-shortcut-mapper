{
	"name": "mac-shortcut-mapper",
	"displayName": "MacOS Keyboard shortcut mapper",
	"version": "0.1.1",
	"description": "Emulate MacOS keyboard shortcuts on Windows with AutoHotKey",
	"categories": [
		"Keymaps"
	],
	"keywords": [
		"vscode",
		"keymap",
		"macos",
		"keyboard",
		"shortcut",
		"autohotkey"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unional/vscode-mac-shortcut-mapper.git"
	},
	"license": "MIT",
	"publisher": "unional",
	"main": "./out/extension.js",
	"scripts": {
		"check": "biome check",
		"compile": "tsc -p ./",
		"cs": "changeset",
		"pretest": "pnpm run compile && pnpm run check",
		"test": "vscode-test",
		"version": "changeset version",
		"publish": "vsce publish",
		"vscode:prepublish": "pnpm run compile",
		"watch": "tsc -watch -p ./"
	},
	"contributes": {
		"commands": [
			{
				"command": "macos-key-mapper.helloWorld",
				"title": "Hello World"
			}
		]
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.28.1",
		"@repobuddy/biome": "^1.7.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/vscode": "^1.80.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.4.1",
		"typescript": "^5.7.3"
	},
	"packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971",
	"engines": {
		"vscode": "^1.80.0"
	},
	"preview": true,
	"extensionKind": [
		"ui"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome"
		]
	}
}
