{
  "name": "mac-shortcut-mapper",
  "displayName": "MacOS Keyboard shortcut mapper",
  "version": "0.0.3",
  "description": "Emulate MacOS keyboard shortcuts on Windows with AutoHotKey",
  "categories": [
    "Keymaps"
  ],
  "keywords": [
    "vscode",
    "keymap",
    "macos",
    "keyboard",
    "shortcut",
    "autohotkey"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unional/vscode-mac-shortcut-mapper.git"
  },
  "license": "MIT",
  "publisher": "unional",
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "pnpm run compile",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "macos-key-mapper.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@repobuddy/biome": "^1.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6",
  "engines": {
    "vscode": "^1.80.0"
  },
  "preview": true,
  "extensionKind": [
    "ui"
  ]
}
